<mujoco model="CR3URDF scene">
  <include file="CR3URDF_with_panda_gripper.xml"/>
  <option gravity="0 0 -9.81"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <default>
    <geom solref="0.02 1" solimp="0.9 0.95 0.001"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <camera name="camera_front" pos="1.0 0 0.5" xyaxes="0 1 0 -0.5 0 1"/>
    
    <camera name="camera_side" pos="0 0.8 0.5" xyaxes="-1 0 0 0 0 1"/>
    
    <camera name="camera_top" pos="0.3 0 1.0" xyaxes="0 1 0 -1 0 0"/>

    <!-- <body mocap="true" name="mocap" pos="0.2 0.3 0.2">
        <site pos="0 0 0.1" size="0.005 0.005 0.1" type="box" name="mocap1" rgba="0 0 1 1"/>
        <site pos="0 0.1 0" size="0.005 0.1 0.005" type="box" name="mocap2" rgba="0 1 0 1"/>
        <site pos="0.1 0 0" size="0.1 0.005 0.005" type="box" name="mocap3" rgba="1 0 0 1"/>
    </body> -->

        <!-- 添加长方体 -->
    <body name="cube" pos="0.4 0 0.02">
      <freejoint/>
      <!-- mass="0.01"  -->
      <geom type="box" size="0.02 0.02 0.02" mass="0.2" rgba="1 0 0 1" friction="1.0 0.3 0.00001"/>
    </body>
  </worldbody>
  <!-- <equality>
        <weld body1="mocap" body2="hand"/>
  </equality> -->
</mujoco>
